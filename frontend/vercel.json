{
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/src/pages/index.html" },
    { "source": "/chat", "destination": "/src/pages/chat.html" },
    { "source": "/dashboard", "destination": "/src/pages/dashboard.html" },
    { "source": "/profile", "destination": "/src/pages/profile.html" },
    { "source": "/settings", "destination": "/src/pages/settings.html" },
    { "source": "/voice", "destination": "/src/pages/voice.html" },
    { "source": "/activities", "destination": "/src/pages/activities.html" },
    { "source": "/payment", "destination": "/src/pages/payment.html" }
  ]
}